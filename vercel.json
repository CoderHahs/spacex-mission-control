{
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install",
    "rewrites": [
        {
            "source": "/api/celestrak/:path*",
            "destination": "https://celestrak.org/NORAD/elements/:path*"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "github": {
        "enabled": true,
        "autoAlias": true,
        "silent": false
    }
}
